{
  "name": "cli-wechat-bridge-web",
  "version": "0.1.0",
  "description": "Standalone web console project for connecting WeChat with Codex",
  "type": "module",
  "private": true,
  "keywords": [
    "wechat",
    "cli",
    "bridge",
    "codex",
    "web-console",
    "terminal"
  ],
  "author": "tyloryang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:tyloryang/CLI-WeChat-Bridge-Web.git"
  },
  "bugs": {
    "url": "https://github.com/tyloryang/CLI-WeChat-Bridge-Web/issues"
  },
  "homepage": "https://github.com/tyloryang/CLI-WeChat-Bridge-Web#readme",
  "scripts": {
    "web:console": "node web-console/server.mjs",
    "bridge": "node --no-warnings --experimental-strip-types src/bridge/wechat-bridge.ts",
    "bridge:codex": "node --no-warnings --experimental-strip-types src/bridge/wechat-bridge.ts --adapter codex",
    "codex:panel": "node --no-warnings --experimental-strip-types src/companion/local-companion.ts --adapter codex"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opencode-ai/sdk": "^1.3.2",
    "ajv-formats": "^3.0.1",
    "node-pty": "^1.1.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.2"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=24.0.0"
  }
}
