# Host-side publish port
HOST_PORT=8080

# Host-side bind mounts
HOST_DATA_DIR=./data
HOST_WORKSPACE_DIR=./workspace
HOST_CODEX_HOME_DIR=./codex-home

# Runtime environment
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=

# Optional: auto-generate Codex relay config.toml for OpenAI-compatible gateways
CODEX_RELAY_BASE_URL=
CODEX_RELAY_MODEL=gpt-5.4
CODEX_RELAY_WIRE_API=responses

WECHAT_ILINK_BASE_URL=https://ilinkai.weixin.qq.com
MAX_LOG_LINES=500
