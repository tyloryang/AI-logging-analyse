# ── Loki 配置 ──────────────────────────────
LOKI_URL=http://localhost:3100
LOKI_USERNAME=
LOKI_PASSWORD=

# ── AI Provider 配置 ────────────────────────
# 选项 A：Anthropic Claude（云端）
#   AI_PROVIDER=anthropic
#   ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
#   AI_MODEL=claude-opus-4-6          # 可选，默认 claude-opus-4-6

# 选项 B：OpenAI 兼容接口（本地模型 / 第三方服务）
#   适用于：Qwen3-32B(vLLM)、Ollama、LM Studio、OpenRouter、DeepSeek 等
#   AI_PROVIDER=openai
#   AI_BASE_URL=http://192.168.x.x:8000/v1   # 必填，你的模型服务地址
#   AI_API_KEY=                               # 本地模型留空；第三方服务填 key
#   AI_MODEL=Qwen3-32B                        # 模型名，与服务端一致

# ── 当前生效配置（修改此处）──────────────────
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# AI_PROVIDER=openai
# AI_BASE_URL=http://192.168.9.x:8000/v1
# AI_API_KEY=
# AI_MODEL=Qwen3-32B

# ── 应用配置 ────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
REPORTS_DIR=./reports
