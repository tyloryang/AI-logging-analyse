# ── Prometheus 配置 ──────────────────────────────
PROMETHEUS_URL=http://prometheus:9090

# ── Loki 配置 ──────────────────────────────
LOKI_URL=http://localhost:3100
LOKI_USERNAME=
LOKI_PASSWORD=

# ── AI Provider 配置 ────────────────────────
# 选项 A：Anthropic Claude（云端）
#   AI_PROVIDER=anthropic
#   ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
#   AI_MODEL=claude-opus-4-6          # 可选，默认 claude-opus-4-6

# 选项 B：OpenAI 兼容接口（本地模型 / 第三方服务）
#   适用于：Qwen3-32B(vLLM)、Ollama、LM Studio、OpenRouter、DeepSeek 等
#   AI_PROVIDER=openai
#   AI_BASE_URL=http://192.168.x.x:8000/v1   # 必填，你的模型服务地址
#   AI_API_KEY=                               # 本地模型留空；第三方服务填 key
#   AI_MODEL=Qwen3-32B                        # 模型名，与服务端一致

# ── 当前生效配置（修改此处）──────────────────
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# AI_PROVIDER=openai
# AI_BASE_URL=http://192.168.9.x:8000/v1
# AI_API_KEY=
# AI_MODEL=Qwen3-32B

# ── 通知推送配置（可选）────────────────────
# 飞书机器人 Webhook（群设置 → 机器人 → 添加机器人 → 自定义机器人）
FEISHU_WEBHOOK=
# 飞书机器人安全策略中配置的关键词（消息必须包含该词才能发送成功）
FEISHU_KEYWORD=

# 钉钉机器人 Webhook（群设置 → 智能群助手 → 添加机器人 → 自定义）
DINGTALK_WEBHOOK=
# 钉钉机器人安全策略中配置的关键词（消息必须包含该词才能发送成功）
# 例如在机器人设置里添加关键词"运维"，这里填 DINGTALK_KEYWORD=运维
DINGTALK_KEYWORD=

# ── 应用配置 ────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
REPORTS_DIR=./reports
# 飞书通知中「查看完整报告」按钮跳转地址（填写前端访问地址，结尾不带斜杠）
# 例如：APP_URL=http://192.168.1.100:5173
APP_URL=

# ── 定时推送配置（可选）────────────────────
# cron 表达式，格式：分 时 日 月 周（服务器本地时间）
# 默认每天 09:00；如需 18:00 推送改为 "0 18 * * *"
SCHEDULE_CRON=0 9 * * *
# 推送渠道，逗号分隔。留空则只生成报告不推送
# 可选值：feishu、dingtalk，支持同时填写
SCHEDULE_CHANNELS=feishu,dingtalk
