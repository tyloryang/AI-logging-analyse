# ================================================================
# AI Ops 日志分析系统 - 环境配置模板
# 复制本文件为 .env 并按需填写
# cp .env.example .env
# ================================================================

# ── Loki 配置 ──────────────────────────────────────────────────
LOKI_URL=http://localhost:3100
LOKI_USERNAME=
LOKI_PASSWORD=

# ── Prometheus 配置 ────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_USERNAME=
PROMETHEUS_PASSWORD=

# ── AI Provider 配置 ───────────────────────────────────────────
# 选项 A：Anthropic Claude（云端）
#   AI_PROVIDER=anthropic
#   ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
#   AI_MODEL=claude-opus-4-6

# 选项 B：OpenAI 兼容接口（本地模型 / 第三方服务）
#   适用于：Qwen3、DeepSeek、vLLM、Ollama、LM Studio、OpenRouter 等
#   AI_PROVIDER=openai
#   AI_BASE_URL=http://192.168.x.x:8000/v1
#   AI_API_KEY=                        # 本地模型留空；第三方填 key
#   AI_MODEL=Qwen3-32B                 # 模型名，与服务端保持一致

# 当前生效配置（从上方选项复制过来修改）
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# AI_BASE_URL=
# AI_API_KEY=
# AI_MODEL=

# ── 数据库配置 ─────────────────────────────────────────────────
# 默认使用 SQLite（无需额外服务，数据存储在 ./data/aiops.db）
DATABASE_URL=sqlite+aiosqlite:///./data/aiops.db

# MySQL 8 示例（需先创建数据库 aiops）：
# DATABASE_URL=mysql+aiomysql://aiops:password@localhost:3306/aiops

# PostgreSQL 示例（需先创建数据库 aiops）：
# DATABASE_URL=postgresql+asyncpg://aiops:password@localhost:5432/aiops

# ── Redis 配置 ─────────────────────────────────────────────────
# 用于存储用户 Session（必填，需部署 Redis 服务）
REDIS_URL=redis://localhost:6379/0
# 有密码示例：redis://:yourpassword@localhost:6379/0

# ── 认证配置 ───────────────────────────────────────────────────
# 初始管理员账号（首次启动且无任何用户时自动创建）
# 创建后修改此处不再生效，请在界面修改密码
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@2026

# Session 滑动过期时长（秒），默认 8 小时
SESSION_TTL_SECONDS=28800

# 登录失败锁定：连续失败 LOGIN_FAIL_MAX 次后锁定账号
# LOGIN_FAIL_WINDOW：失败计数滑动窗口（秒）
LOGIN_FAIL_MAX=5
LOGIN_FAIL_WINDOW=600

# ── 通知推送配置（可选）────────────────────────────────────────
# 飞书自定义机器人 Webhook（群设置 -> 机器人 -> 添加 -> 自定义机器人）
FEISHU_WEBHOOK=
# 飞书机器人安全策略关键词（消息必须包含该词才能发送）
FEISHU_KEYWORD=运维

# 钉钉自定义机器人 Webhook（群设置 -> 智能群助手 -> 添加 -> 自定义）
DINGTALK_WEBHOOK=
# 钉钉机器人安全策略关键词
DINGTALK_KEYWORD=运维

# ── 应用配置 ───────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
REPORTS_DIR=./reports

# 飞书/钉钉通知中「查看完整报告」按钮的跳转地址（结尾不带斜杠）
APP_URL=http://192.168.x.x:5173

# ── 定时推送配置（可选）────────────────────────────────────────
# cron 表达式，格式：分 时 日 月 周（服务器本地时间）
SCHEDULE_CRON=0 9 * * *
# 推送渠道，逗号分隔，留空则只生成报告不推送
# 可选值：feishu、dingtalk
SCHEDULE_CHANNELS=feishu,dingtalk
