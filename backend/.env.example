# ==============================================================
# AI Ops 智能运维平台 — 环境变量配置示例
# 复制为 .env 并按实际情况填写
# ==============================================================

# ── 数据源 ─────────────────────────────────────────────────────
LOKI_URL=http://your-loki-host:3100
LOKI_USERNAME=                          # 无认证留空
LOKI_PASSWORD=                          # 无认证留空
LOKI_DEMO_MODE=0                        # 设为 1 使用内置日志样例数据

PROMETHEUS_URL=http://your-prometheus-host:9090
PROMETHEUS_USERNAME=                    # 无认证留空
PROMETHEUS_PASSWORD=                    # 无认证留空

# Alertmanager（用于连通性测试、静默扩展、前端配置回填；Webhook 接收地址见告警中心页面）
ALERTMANAGER_URL=http://your-alertmanager-host:9093
ALERTMANAGER_USERNAME=                  # 无认证留空
ALERTMANAGER_PASSWORD=                  # 无认证留空

# ── 数据库 ─────────────────────────────────────────────────────
# SQLite（默认，无需额外服务）
DATABASE_URL=sqlite+aiosqlite:///./data/aiops.db
# MySQL 8
# DATABASE_URL=mysql+aiomysql://user:pass@host:3306/aiops
# PostgreSQL 16
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/aiops

# ── Redis（Session + 登录失败计数）────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI Provider（二选一）──────────────────────────────────────
# 选项 A：Anthropic Claude
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
AI_MODEL=claude-opus-4-6

# 选项 B：本地 / 第三方 OpenAI 兼容接口（vLLM / Ollama / 代理）
# AI_PROVIDER=openai
# AI_BASE_URL=http://192.168.x.x:8000/v1
# AI_API_KEY=                           # 本地服务可留空
# AI_MODEL=Qwen3-32B
# AI_WIRE_API=chat                      # chat（默认）| responses（仅支持 /v1/responses 的代理）

# ── Milvus 向量长期记忆 ────────────────────────────────────────
MILVUS_HOST=192.168.9.227
MILVUS_PORT=19530

# Neo4j knowledge graph (leave NEO4J_URI empty to keep SQLite-only mode)
# Docker Compose profile: docker compose --profile neo4j up -d neo4j
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_CONNECTION_TIMEOUT=1
NEO4J_ACQUISITION_TIMEOUT=1.5
NEO4J_CONNECTION_WRITE_TIMEOUT=2
NEO4J_RETRY_TIME=0
NEO4J_FAILURE_COOLDOWN=30

# Embedding（方式 A：本地服务 / 代理，设置 EMBEDDING_PROVIDER=local）
EMBEDDING_PROVIDER=local
EMBEDDING_BASE_URL=https://api.gpt.ge/v1
EMBEDDING_API_KEY=sk-xxxxxx
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Embedding（方式 B：OpenAI 官方，改 EMBEDDING_PROVIDER=openai，注释掉 EMBEDDING_BASE_URL）
# EMBEDDING_PROVIDER=openai
# EMBEDDING_API_KEY=sk-xxxxxx
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536

# ── 初始管理员（首次启动自动创建）────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=                         # Set a strong value; empty generates a one-time random password at first startup

# ── 定时推送（飞书 / 钉钉）────────────────────────────────────
SCHEDULE_CRON=0 9 * * *                 # 每天 09:00，留空禁用
SCHEDULE_CHANNELS=feishu                # feishu | dingtalk | feishu,dingtalk

FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# 用于飞书 RCA 完成卡片中的“查看完整 RCA 证据”链接
AIOPS_PUBLIC_URL=https://aiops.example.com
FEISHU_KEYWORD=运维

DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
DINGTALK_KEYWORD=运维

# ── 飞书事件回调（事件发送至开发者服务器）────────────────────
FEISHU_BOT_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_BOT_APP_SECRET=your_feishu_app_secret
FEISHU_BOT_ENCRYPT_KEY=                # 可选：开启事件加密时配置
FEISHU_BOT_VERIFY_TOKEN=               # 可选：URL 验证 / 事件 token 校验
FEISHU_ALLOW_UNVERIFIED=0              # 仅本地开发可设为 1；生产环境必须校验 token
FEISHU_REQUIRE_MENTION=1               # 群聊是否必须 @ 机器人后才回复：1=必须 @，0=不 @ 也回复

# ── 服务启动参数 ───────────────────────────────────────────────
FEISHU_CALLBACK_HOST=0.0.0.0
FEISHU_CALLBACK_PORT=8001
FEISHU_CALLBACK_PUBLIC_BASE_URL=       # Optional, e.g. https://your-domain:8001

# Agent ReAct / 快速路径
# 默认走 LangGraph ReAct：边执行工具边综合回答；如需恢复旧的一问一答快速路径，设为 1
AIOPS_QUICK_ACTIONS=0
FEISHU_QUICK_ACTIONS=0
# Agent 执行器：langgraph（内置）| aiops_cli（本项目 CLI 子进程）| external_cli（Claude Code / Codex 等外部 CLI）
AIOPS_AGENT_EXECUTOR=langgraph
# external_cli 模式配置；命令留空时会自动查找 `claude`，Claude Code 推荐参数 `-p`
AIOPS_EXTERNAL_AGENT_COMMAND=
AIOPS_EXTERNAL_AGENT_ARGS=-p
AIOPS_EXTERNAL_AGENT_USE_STDIN=0
AIOPS_EXTERNAL_AGENT_TIMEOUT=240
AIOPS_EXTERNAL_AGENT_WORKDIR=
# 飞书 ReAct 进度：1=工具调用时发送进度消息；0=只发送最终结果
FEISHU_REACT_PROGRESS=1
# 最终回复是否附带工具执行轨迹
FEISHU_REACT_TRACE_IN_FINAL=1

APP_HOST=0.0.0.0
APP_PORT=8000
GZIP_ENABLED=1                          # Enable gzip for large API responses; stream/SSE endpoints are skipped
GZIP_MIN_SIZE=1024                      # Only compress responses >= this many bytes
GZIP_COMPRESS_LEVEL=6                   # 1=fastest, 9=smallest
DEV_RELOAD=false                        # 开发模式热重载

# ── 安全 / Session ─────────────────────────────────────────────
SESSION_TTL_SECONDS=86400               # Session 有效期（秒），默认 24h
SESSION_COOKIE_SECURE=0                 # HTTPS 生产环境设为 1；反向代理需传 X-Forwarded-Proto
SESSION_ALLOW_MEMORY_FALLBACK=0         # Redis 故障时默认拒绝降级，单机开发可显式设为 1
LOGIN_FAIL_MAX=5                        # 登录失败锁定阈值
LOGIN_FAIL_WINDOW=300                   # 登录失败统计窗口（秒）
LOGIN_IP_FAIL_MAX=20                    # 单个来源 IP 在窗口内的失败上限

# ── 外部事件入口（浏览器 CORS 已全局允许任意 Origin）──────────
EVENTS_INGEST_TOKEN=                    # 外部事件入口 token；留空时入口关闭（503）
EVENTS_ALLOW_UNAUTHENTICATED=0          # 仅本地开发可显式设为 1
ALERTS_INGEST_TOKEN=                    # Alertmanager webhook token；留空时入口关闭（503）
ALERTS_ALLOW_UNAUTHENTICATED=0          # 仅本地开发可显式设为 1

# ── 文件路径（通常无需修改）───────────────────────────────────
# 容器部署强烈建议固定 SSH_FERNET_KEY，避免重启后旧凭证无法解密
# SSH_FERNET_KEY=由 `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"` 生成
SSH_FERNET_KEY=
SSH_STRICT_HOST_KEY_CHECKING=1          # 默认校验服务端主机密钥
SSH_KNOWN_HOSTS=                        # 可指定独立 known_hosts 文件
JENKINS_VERIFY_TLS=1                    # 默认校验 Jenkins HTTPS 证书
REPORTS_DIR=./reports
# 以下路径仅用于首次导入历史 CMDB JSON；导入后数据库是唯一数据源
CMDB_FILE=./data/cmdb_hosts.json
CREDENTIALS_FILE=./data/ssh_credentials.json
GROUPS_FILE=./data/groups.json
USER_GROUPS_FILE=./data/user_groups.json
SSH_KEY_FILE=./data/.ssh_key
SLOWLOG_TARGETS_FILE=./data/slowlog_targets.json

# ── 主机资产 SSH 同步 ────────────────────────────────────────
HOST_SYNC_SSH_CONNECT_TIMEOUT=12          # SSH 建连超时（秒）
HOST_SYNC_SSH_COMMAND_TIMEOUT=20          # SSH 信息采集命令超时（秒）
